[global]
ioengine=io_uring_cmd
cmd_type=nvme
sqthread_poll=1
direct=0
size=1G
time_based=1
runtime=20
randrepeat=0

[cachelib_bighash]
# CacheLib typically handles primarily inserts from miss/eviction and high writes
rw=randrw
rwmixread=20
# Mix of small and larger cache objects
bssplit=4k/50:16k/30:64k/20
# Pareto distribution to simulate heavy tail Cache access patterns
random_distribution=pareto:0.9
